# OpenAI API key (required for AI analysis)
OPENAI_API_KEY=sk-xxxx

# Etherscan API key (free — register at etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Pinata IPFS credentials (free — register at pinata.cloud)
PINATA_GATEWAY=https://your-gateway.mypinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt

# Sepolia testnet RPC (free — get from infura.io or alchemy.com)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key

# AuditRegistry contract address (fill in after deploying via Remix)
AUDIT_REGISTRY_ADDRESS=0x1097fdb5c04bF892D4754786c8d3d0bd24F29247

# Private key of the wallet used to submit transactions (no real funds needed on testnet)
DEPLOYER_PRIVATE_KEY=your_wallet_private_key
